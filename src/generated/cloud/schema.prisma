generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/cloud"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_CLOUD")
  directUrl = env("DIRECT_URL")
}

model Playlist {
  id          Int               @id @default(autoincrement())
  nombre      String
  descripcion String            @default("")
  imagenUrl   String            @default("")
  esFavoritos Boolean           @default(false)
  oculta      Boolean           @default(false)
  orden       Int               @default(0)
  createdAt   DateTime          @default(now())
  canciones   PlaylistCancion[]
}

model PlaylistCancion {
  id         Int      @id @default(autoincrement())
  playlistId Int
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model Config {
  id        Int    @id @default(1)
  fichas    Int    @default(0)
  fichasHoy Int    @default(0)
  fechaHoy  String @default("")
}

model AppConfig {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

model PagoProcesado {
  ref      String   @id
  creadoEn DateTime @default(now())
}

model Cola {
  id         Int      @id @default(autoincrement())
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  tipo       String   @default("cliente")
  createdAt  DateTime @default(now())
}
