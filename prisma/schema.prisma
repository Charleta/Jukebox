generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Config {
  id     Int @id @default(1)
  fichas Int @default(0)
}

model Cola {
  id         Int      @id @default(autoincrement())
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  createdAt  DateTime @default(now())
}

model Playlist {
  id          Int               @id @default(autoincrement())
  nombre      String
  descripcion String            @default("")
  imagenUrl   String            @default("")
  createdAt   DateTime          @default(now())
  canciones   PlaylistCancion[]
}

model PlaylistCancion {
  id         Int      @id @default(autoincrement())
  playlistId Int
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}