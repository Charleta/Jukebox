generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/cloud"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_CLOUD")
  directUrl = env("DIRECT_URL")
}

model Playlist {
  id          Int               @id @default(autoincrement())
  nombre      String
  descripcion String            @default("")
  imagenUrl   String            @default("")
  esFavoritos Boolean           @default(false)
  oculta      Boolean           @default(false)
  orden       Int               @default(0)
  createdAt   DateTime          @default(now())
  canciones   PlaylistCancion[]
}

model PlaylistCancion {
  id         Int      @id @default(autoincrement())
  playlistId Int
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model Config {
  id        Int    @id @default(1)
  fichas    Int    @default(0)
  fichasHoy Int    @default(0)
  fechaHoy  String @default("")
}

model AppConfig {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

model PagoProcesado {
  ref      String   @id
  creadoEn DateTime @default(now())
}

model Cola {
  id         Int      @id @default(autoincrement())
  titulo     String
  artista    String
  duracion   Int
  spotifyUri String
  imagenUrl  String
  orden      Int
  tipo       String   @default("cliente")
  createdAt  DateTime @default(now())
}

model Venue {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  devices   Device[]
  sessions  DeviceSession[]
  attempts  AccessAttempt[]
}

model Device {
  id          String         @id @default(cuid())
  venueId     String
  fingerprint String         @unique
  name        String
  alias       String         @default("")
  role        String
  status      String         @default("pending")
  approved    Boolean        @default(false)
  lastSeenAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  venue       Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sessions    DeviceSession[]
  attempts    AccessAttempt[]
}

model DeviceSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  deviceId  String
  venueId   String
  role      String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model AccessAttempt {
  id          String   @id @default(cuid())
  venueId     String
  deviceId    String?
  fingerprint String
  surface     String
  path        String
  result      String
  message     String   @default("")
  userAgent   String
  createdAt   DateTime @default(now())
  device      Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}
